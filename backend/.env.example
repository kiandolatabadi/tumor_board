# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-...

# The panel model. All specialist reasoning + synthesis runs on this — Sonnet is
# the right default now that the thinking is done by the LLM, not hard-coded logic.
PANEL_MODEL=claude-sonnet-5

# Optional panel tuning.
# PANEL_MAX_ROUNDS=2          # 1 parallel pass + this many cross-examination rounds
# PANEL_MAX_PARALLEL=6        # specialists consulted concurrently
# PANEL_MAX_OUTPUT_TOKENS=8000

# CORS origin for the frontend. Set to your deployed frontend URL in production.
FRONTEND_ORIGIN=http://localhost:5173
